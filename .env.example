APP_NAME="DPP Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL 14+ required (JSONB, partial indexes, declarative partitioning, citext).
# The target database needs the `citext` and `pgcrypto` extensions enabled.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=dpp
DB_USERNAME=dpp
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Passwordless login emails the code, so working SMTP is required in production.
MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Object storage: local disk in dev, S3-compatible in prod (config-only switch).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- DPP platform ---
# Base URL that scanned QR codes encode and resolve to. Must be HTTPS and stable forever
# in production (QR carriers are permanent and cannot be reprinted).
PASSPORT_BASE_URL="${APP_URL}"
# Default Member-State language for the public passport layer.
PASSPORT_DEFAULT_LOCALE=lv
# Keyed HMAC secret for hashing scanner IPs (GDPR). Defaults to APP_KEY if unset.
SCAN_IP_HMAC_KEY=

VITE_APP_NAME="${APP_NAME}"
